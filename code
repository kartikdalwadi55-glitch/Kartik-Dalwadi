from scapy.all import sniff, IP, TCP, UDP, ICMP
from collections import Counter
from datetime import datetime

# Global Counters
packet_count = 0
tcp_count = 0
udp_count = 0
icmp_count = 0

source_ips = Counter()
destination_ports = Counter()

# Suspicious Ports
suspicious_ports = [21, 23, 445, 3389]


def analyze_packet(packet):
    global packet_count, tcp_count, udp_count, icmp_count

    packet_count += 1

    print("\n========================================")
    print(f"Packet Number : {packet_count}")
    print("Timestamp     :", datetime.now().strftime("%Y-%m-%d %H:%M:%S"))

    if packet.haslayer(IP):

        ip = packet[IP]

        source_ips[ip.src] += 1

        print("Source IP      :", ip.src)
        print("Destination IP :", ip.dst)

        # TCP
        if packet.haslayer(TCP):

            tcp_count += 1

            sport = packet[TCP].sport
            dport = packet[TCP].dport

            destination_ports[dport] += 1

            print("Protocol       : TCP")
            print("Source Port    :", sport)
            print("Destination Port:", dport)

            if dport in suspicious_ports:
                print("WARNING : Sensitive Port Access Detected!")

        # UDP
        elif packet.haslayer(UDP):

            udp_count += 1

            sport = packet[UDP].sport
            dport = packet[UDP].dport

            destination_ports[dport] += 1

            print("Protocol       : UDP")
            print("Source Port    :", sport)
            print("Destination Port:", dport)

        # ICMP
        elif packet.haslayer(ICMP):

            icmp_count += 1

            print("Protocol       : ICMP")


def show_report():

    print("\n")
    print("=" * 50)
    print("      NETWORK TRAFFIC ANALYSIS REPORT")
    print("=" * 50)

    print(f"Total Packets Captured : {packet_count}")
    print(f"TCP Packets            : {tcp_count}")
    print(f"UDP Packets            : {udp_count}")
    print(f"ICMP Packets           : {icmp_count}")

    print("\nTop 5 Source IP Addresses")

    for ip, count in source_ips.most_common(5):
        print(f"{ip:<20} {count} packets")

    print("\nTop 5 Destination Ports")

    for port, count in destination_ports.most_common(5):
        print(f"Port {port:<8} {count} packets")

    print("=" * 50)


print("=" * 50)
print(" Real-Time Network Traffic Analyzer")
print("=" * 50)
print("Capturing 100 packets...")
print("Please generate some network traffic.")
print("=" * 50)

# Capture 100 packets
sniff(prn=analyze_packet, store=False, count=100)

# Final Report
show_report()
